# ==============================================================================
# NEET MCQ Tracker - Production Environment Template
# ==============================================================================
# Rename this file to .env and fill in the actual values before deployment.
# DO NOT COMMIT your actual .env file to version control.

# --- 1. Server Configuration ---
# Render assigns PORT dynamically, but you can set a fallback for local testing
PORT=3847
# Optional: Legacy pin-based auth (leave empty if migrating fully to Clerk)
SERVER_PIN=

# --- 2. Database (MongoDB) ---
# Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/neet_tracker?retryWrites=true&w=majority

# --- 3. Authentication (Clerk / Google OAuth) ---
# Required for securing endpoints. Obtain these from your Clerk Dashboard.
# The backend only strictly needs the SECRET_KEY to verify tokens.
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- 4. WebRTC / LiveKit (Study Room) ---
# Required for the live study room signaling
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
